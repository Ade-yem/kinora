generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Auth.js / NextAuth models
model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Domain models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")

  profile        UserProfile?
  accounts       Account[]
  sessions       Session[]
  chatSessions   ChatSession[]
  workoutRoutines WorkoutRoutine[]
  workoutLogs    WorkoutLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model UserProfile {
  id                     String             @id @default(cuid())
  userId                 String             @unique @map("user_id")
  goal                   String?
  location               Location?
  equipment              String[]
  sessionDurationMinutes Int?               @map("session_duration_minutes")
  injuries               Json?
  injuriesNotes          String?            @map("injuries_notes")
  unitsPreference        String             @default("lb") @map("units_preference")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model Exercise {
  id                         String                       @id @default(cuid())
  name                       String
  shortDemoVideoUrl          String?                      @map("short_demo_video_url")
  inDepthExplanationVideoUrl String?                      @map("in_depth_explanation_video_url")
  difficultyLevel            String?                      @map("difficulty_level")
  targetMuscleGroup          TargetMuscleGroup?           @map("target_muscle_group")
  primeMoverMuscle           String?                      @map("prime_mover_muscle")
  secondaryMuscle            String?                      @map("secondary_muscle")
  tertiaryMuscle             String?                      @map("tertiary_muscle")
  primaryEquipment           String?                      @map("primary_equipment")
  primaryEquipmentCount      Int?                         @map("primary_equipment_count")
  secondaryEquipment         String?                      @map("secondary_equipment")
  secondaryEquipmentCount    Int?                         @map("secondary_equipment_count")
  posture                    String?
  armLaterality              String?                      @map("arm_laterality")
  armMovementPattern         String?                      @map("arm_movement_pattern")
  grip                       String?
  loadPositionEnding         String?                      @map("load_position_ending")
  legMovementPattern         String?                      @map("leg_movement_pattern")
  footElevation              String?                      @map("foot_elevation")
  combinationExercises       String?                      @map("combination_exercises")
  movementPattern1           String?                      @map("movement_pattern_1")
  movementPattern2           String?                      @map("movement_pattern_2")
  movementPattern3           String?                      @map("movement_pattern_3")
  planeOfMotion1             String?                      @map("plane_of_motion_1")
  planeOfMotion2             String?                      @map("plane_of_motion_2")
  planeOfMotion3             String?                      @map("plane_of_motion_3")
  bodyRegion                 BodyRegion?                  @map("body_region")
  forceType                  String?                      @map("force_type")
  mechanics                  String?
  laterality                 String?
  primaryClassification      PrimaryExerciseClassification? @map("primary_classification")
  instructions               Json?

  routineItems RoutineItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@index([targetMuscleGroup])
  @@index([bodyRegion])
  @@index([primaryClassification])
  @@map("exercises")
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String?
  messages  ChatMessage[]
  routines  WorkoutRoutine[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("chat_sessions")
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String      @map("chat_session_id")
  role          ChatRole
  kind          ChatMessageKind @default(TEXT)
  text          String
  chip          String?

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([chatSessionId, createdAt])
  @@map("chat_messages")
}

model WorkoutRoutine {
  id            String      @id @default(cuid())
  chatSessionId String      @map("chat_session_id")
  userId        String      @map("user_id")
  title         String
  subtitle      String?
  status        RoutineStatus @default(PENDING_GENERATION)
  reviewNotes   Json?       @map("review_notes")
  finalizedAt   DateTime?   @map("finalized_at")
  programId     String?     @map("program_id")
  dayIndex      Int?        @map("day_index")
  totalDays     Int?        @map("total_days")

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       RoutineItem[]
  logs        WorkoutLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, status])
  @@map("workout_routines")
}

model RoutineItem {
  id            String         @id @default(cuid())
  routineId     String         @map("routine_id")
  exerciseId    String         @map("exercise_id")
  order         Int
  sets          Int
  targetReps    Int?           @map("target_reps")
  targetSeconds Int?           @map("target_seconds")
  targetSide    String?        @map("target_side")

  routine   WorkoutRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise  Exercise       @relation(fields: [exerciseId], references: [id])

  @@unique([routineId, order])
  @@index([routineId])
  @@map("routine_items")
}

model WorkoutLog {
  id              String   @id @default(cuid())
  routineId       String   @map("routine_id")
  userId          String   @map("user_id")
  performedAt     DateTime @default(now()) @map("performed_at")
  durationSeconds Int?     @map("duration_seconds")
  entries         Json
  totalVolumeKg   Float?   @map("total_volume_kg")

  routine WorkoutRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, performedAt])
  @@index([routineId])
  @@map("workout_logs")
}

// Enums
enum Location {
  HOME
  GYM
}

enum RoutineStatus {
  PENDING_GENERATION
  PENDING_REVIEW
  REJECTED
  APPROVED
}

enum ChatRole {
  COACH
  USER
}

enum ChatMessageKind {
  TEXT
  GUARDRAIL
  PATCH
}

enum BodyRegion {
  LOWER_BODY
  UPPER_BODY
  FULL_BODY
  CORE
}

enum TargetMuscleGroup {
  QUADRICEPS
  SHOULDERS
  ABDOMINALS
  BACK
  GLUTES
  CHEST
  BICEPS
  TRICEPS
  HIP_FLEXORS
  CALVES
  HAMSTRINGS
  FOREARMS
  ABDUCTORS
  ADDUCTORS
  TRAPEZIUS
  SHINS
}

enum PrimaryExerciseClassification {
  BODYBUILDING
  CALISTHENICS
  BALLISTICS
  BALANCE
  PLYOMETRIC
  OLYMPIC_WEIGHTLIFTING
  MOBILITY
  GRINDS
  POSTURAL
  ANIMAL_FLOW
  POWERLIFTING
  UNSORTED
}
